@inject NavigationManager Nav
@inject AppStateService AppState
@inject IJSRuntime JS

<div style="width:@(collapsed ? "64px" : "248px"); flex:none; background:var(--sidebar-bg);
            border-right:1px solid var(--border-dim); display:flex; flex-direction:column;
            transition:width 0.2s ease; overflow:hidden;">

    @if (!collapsed)
    {
        <!-- Expanded sidebar -->
        <div style="padding:28px 20px; display:flex; flex-direction:column; height:100%;">

            <!-- Header -->
            <div style="display:flex; align-items:center; gap:11px; margin-bottom:40px; padding:0 6px;">
                <div style="width:26px; height:26px; border-radius:7px; background:var(--accent);
                            display:flex; align-items:center; justify-content:center; flex:none;">
                    <div style="width:9px; height:9px; background:#0a0a0c; transform:rotate(45deg);"></div>
                </div>
                <div style="font-size:15px; color:var(--text-primary); font-weight:600; letter-spacing:0.01em; flex:1;">
                    Patrimonio
                </div>
                <div @onclick="Toggle" title="Contraer"
                     style="width:28px; height:28px; border-radius:7px; display:flex; align-items:center;
                            justify-content:center; color:var(--text-faint); cursor:pointer;">
                    <svg width="16" height="16" viewBox="0 0 16 16">
                        <polyline points="9,3 4,8 9,13" fill="none" stroke="currentColor" stroke-width="1.6"
                                  stroke-linejoin="round" stroke-linecap="round"/>
                        <line x1="12" y1="3" x2="12" y2="13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    </svg>
                </div>
            </div>

            <!-- Nav section label -->
            <div style="font-size:10px; font-family:var(--font-mono); color:var(--text-darkest);
                        letter-spacing:0.1em; padding:0 12px; margin-bottom:10px;">PRINCIPAL</div>

            <!-- Nav items -->
            @foreach (var item in NavItems)
            {
                <div @onclick="() => Navigate(item.Href)"
                     style="display:flex; align-items:center; gap:12px; padding:11px 12px; border-radius:9px;
                            margin-bottom:3px; cursor:pointer;
                            background:@NavBg(item.Href); color:@NavColor(item.Href);">
                    <svg width="16" height="16" viewBox="0 0 16 16">@((MarkupString)item.Icon)</svg>
                    <span style="font-size:14px;">@item.Label</span>
                </div>
            }

            <!-- Settings -->
            <div style="margin-top:16px; padding:0 12px;">
                <div style="font-size:10px; font-family:var(--font-mono); color:var(--text-darkest);
                            letter-spacing:0.1em; margin-bottom:10px;">AJUSTES</div>

                <!-- Accent picker -->
                <div style="display:flex; gap:8px; margin-bottom:10px;">
                    @foreach (var (name, color) in Accents)
                    {
                        <div @onclick="() => SetAccent(color)" title="@name"
                             style="width:20px; height:20px; border-radius:50%; background:@color; cursor:pointer;
                                    border:2px solid @(AppState.AccentColor == color ? "var(--text-primary)" : "transparent");
                                    transition:border-color 0.15s;">
                        </div>
                    }
                </div>

                <!-- Privacy toggle -->
                <div @onclick="AppState.TogglePrivacy" style="display:flex; align-items:center; gap:8px;
                     font-size:12px; color:var(--text-faint); cursor:pointer; padding:6px 0;">
                    @if (AppState.PrivacyMode)
                    {
                        <svg width="14" height="14" viewBox="0 0 16 16">
                            <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" fill="none" stroke="currentColor" stroke-width="1.4"/>
                            <line x1="2" y1="2" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="14" height="14" viewBox="0 0 16 16">
                            <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" fill="none" stroke="currentColor" stroke-width="1.4"/>
                            <circle cx="8" cy="8" r="2" fill="currentColor"/>
                        </svg>
                    }
                    <span>@(AppState.PrivacyMode ? "Mostrar valores" : "Ocultar valores")</span>
                </div>
            </div>

            <!-- User footer -->
            <div style="margin-top:auto; border-top:1px solid var(--border-dim); padding-top:18px;
                        display:flex; align-items:center; gap:11px; padding-left:6px;">
                <div style="width:32px; height:32px; border-radius:50%;
                            background:linear-gradient(135deg,#3a3147,#211c2c);
                            border:1px solid #2a2435; flex:none;"></div>
                <div>
                    <div style="font-size:13px; color:var(--text-secondary);">Mi cuenta</div>
                    <div style="font-size:11px; color:var(--text-dead); font-family:var(--font-mono);">trader</div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Collapsed sidebar -->
        <div style="padding:24px 0; display:flex; flex-direction:column; align-items:center; gap:8px; height:100%;">

            <div @onclick="Toggle" title="Expandir"
                 style="width:30px; height:30px; border-radius:8px; background:var(--accent);
                        display:flex; align-items:center; justify-content:center; margin-bottom:18px; cursor:pointer;">
                <div style="width:10px; height:10px; background:#0a0a0c; transform:rotate(45deg);"></div>
            </div>

            @foreach (var item in NavItems)
            {
                <div @onclick="() => Navigate(item.Href)" title="@item.Label"
                     style="width:40px; height:40px; border-radius:9px; display:flex; align-items:center;
                            justify-content:center; cursor:pointer;
                            background:@NavBg(item.Href); color:@NavColor(item.Href);">
                    <svg width="16" height="16" viewBox="0 0 16 16">@((MarkupString)item.Icon)</svg>
                </div>
            }

            <div style="margin-top:auto; width:30px; height:30px; border-radius:50%;
                        background:linear-gradient(135deg,#3a3147,#211c2c); border:1px solid #2a2435;"></div>
        </div>
    }
</div>

@code {
    private bool collapsed = false;

    private record NavItem(string Label, string Href, string Icon);

    private static readonly List<NavItem> NavItems =
    [
        new("Resumen", "/",
            "<rect x='1' y='1' width='6' height='6' rx='1.5' fill='currentColor'/><rect x='9' y='1' width='6' height='6' rx='1.5' fill='currentColor'/><rect x='1' y='9' width='6' height='6' rx='1.5' fill='currentColor'/><rect x='9' y='9' width='6' height='6' rx='1.5' fill='currentColor'/>"),
        new("Cuentas", "/cuentas",
            "<rect x='1' y='3' width='14' height='10' rx='2' fill='none' stroke='currentColor' stroke-width='1.4'/><circle cx='11.5' cy='8' r='1.3' fill='currentColor'/>"),
        new("Trades", "/trades",
            "<polyline points='1,12 5,7 9,9 15,2' fill='none' stroke='currentColor' stroke-width='1.4' stroke-linejoin='round' stroke-linecap='round'/>"),
        new("Analítica", "/analitica",
            "<rect x='1' y='9' width='3' height='6' rx='1' fill='currentColor'/><rect x='6.5' y='5' width='3' height='10' rx='1' fill='currentColor'/><rect x='12' y='1' width='3' height='14' rx='1' fill='currentColor'/>"),
        new("Estrategias", "/estrategias",
            "<circle cx='8' cy='8' r='6.3' fill='none' stroke='currentColor' stroke-width='1.4'/><circle cx='8' cy='8' r='1.6' fill='currentColor'/>"),
    ];

    private static readonly List<(string Name, string Color)> Accents =
    [
        ("Morado", "#8b7bb3"),
        ("Plata", "#b9b3c2"),
        ("Índigo", "#8189c8"),
    ];

    private void Toggle() => collapsed = !collapsed;

    private void Navigate(string href) => Nav.NavigateTo(href);

    private bool IsActive(string href) =>
        href == "/" ? Nav.Uri == Nav.BaseUri || Nav.Uri.TrimEnd('/') == Nav.BaseUri.TrimEnd('/')
                    : Nav.Uri.Contains(href);

    private string NavBg(string href) => IsActive(href) ? "var(--hover-bg)" : "transparent";
    private string NavColor(string href) => IsActive(href) ? "var(--accent)" : "var(--text-faint)";

    private async Task SetAccent(string color)
    {
        AppState.SetAccent(color);
        await JS.InvokeVoidAsync("setAccent", color);
    }
}
