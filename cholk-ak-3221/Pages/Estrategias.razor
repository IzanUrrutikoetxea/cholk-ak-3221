@page "/estrategias"
@inject DataStore Store

<PageTitle>Estrategias — Cholk</PageTitle>

<div class="page-content">

    <!-- Header -->
    <div class="page-header">
        <div>
            <div class="page-title">Estrategias</div>
            <div class="page-subtitle">@strategies.Count setups</div>
        </div>
        <button class="btn-primary" @onclick="OpenAddStrategy">
            <span class="btn-plus">+</span> Nueva estrategia
        </button>
    </div>

    <div class="grid-2">
        @foreach (var s in strategies)
        {
            <div class="card">
                <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:18px;">
                    <div>
                        <div style="font-size:16px; color:var(--text-primary); font-weight:600;">@s.Name</div>
                        <div style="font-size:12px; color:var(--text-ghost); margin-top:4px;">@s.Description</div>
                    </div>
                    @if (s.Status == StrategyStatus.Profitable)
                    {
                        <Badge Text="Rentable" Variant="profitable" />
                    }
                    else if (s.Status == StrategyStatus.UnderReview)
                    {
                        <Badge Text="En revisión" Variant="review" />
                    }
                    else
                    {
                        <Badge Text="Inactiva" Variant="challenge" />
                    }
                </div>

                <div style="display:flex; gap:24px; margin-bottom:18px;">
                    <div>
                        <div class="stat-label-sm">P&amp;L</div>
                        <div style="font-family:var(--font-mono); font-size:20px; margin-top:6px;
                                    color:@(s.TotalPnl >= 0 ? "var(--green)" : "var(--red)");">
                            @(s.TotalPnl >= 0 ? "+" : "")@s.TotalPnl.ToString("N0") €
                        </div>
                    </div>
                    <div>
                        <div class="stat-label-sm">WIN RATE</div>
                        <div style="font-family:var(--font-mono); font-size:20px; margin-top:6px;">
                            @s.WinRate.ToString("F0")%
                        </div>
                    </div>
                    <div>
                        <div class="stat-label-sm">PF</div>
                        <div style="font-family:var(--font-mono); font-size:20px; margin-top:6px;">
                            @s.ProfitFactor.ToString("F1")
                        </div>
                    </div>
                    <div>
                        <div class="stat-label-sm">TRADES</div>
                        <div style="font-family:var(--font-mono); font-size:20px; margin-top:6px;">
                            @s.TradeCount
                        </div>
                    </div>
                </div>

                <Sparkline Values="@s.EquityHistory"
                           Color="@(s.Status == StrategyStatus.UnderReview ? "var(--red)" : "var(--accent)")"
                           Width="460" Height="42" />
            </div>
        }

        <!-- Add card -->
        <div class="card-add" style="min-height:170px;" @onclick="OpenAddStrategy">
            <div class="card-add-circle">+</div>
            <div style="font-size:13px;">Crear nueva estrategia</div>
        </div>
    </div>
</div>

<!-- Add Strategy Modal -->
@if (showAddModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-title">Nueva estrategia</div>
            <div class="form-group">
                <label class="form-label">Nombre</label>
                <input class="form-control" @bind="newStrategy.Name" placeholder="Ej. Breakout London" />
            </div>
            <div class="form-group">
                <label class="form-label">Descripción</label>
                <input class="form-control" @bind="newStrategy.Description"
                       placeholder="Ej. Rupturas en la apertura de Londres · H1" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Win Rate (%)</label>
                    <input class="form-control" type="number" @bind="newStrategy.WinRate" />
                </div>
                <div class="form-group">
                    <label class="form-label">Profit Factor</label>
                    <input class="form-control" type="number" step="0.1" @bind="newStrategy.ProfitFactor" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Estado</label>
                    <select class="form-control" @bind="newStrategy.Status">
                        <option value="@StrategyStatus.Profitable">Rentable</option>
                        <option value="@StrategyStatus.UnderReview">En revisión</option>
                        <option value="@StrategyStatus.Inactive">Inactiva</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">P&L total (€)</label>
                    <input class="form-control" type="number" @bind="newStrategy.TotalPnl" />
                </div>
            </div>
            <div class="form-actions">
                <button class="btn-secondary" @onclick="CloseModal">Cancelar</button>
                <button class="btn-primary" @onclick="SaveStrategy">Guardar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Strategy> strategies = new();
    private bool showAddModal = false;
    private Strategy newStrategy = new();

    protected override async Task OnInitializedAsync()
        => strategies = await Store.GetStrategiesAsync();

    private void OpenAddStrategy() { newStrategy = new(); showAddModal = true; }
    private void CloseModal() => showAddModal = false;

    private async Task SaveStrategy()
    {
        if (string.IsNullOrWhiteSpace(newStrategy.Name)) return;
        newStrategy.EquityHistory = [0, newStrategy.TotalPnl];
        await Store.AddStrategyAsync(newStrategy);
        strategies = await Store.GetStrategiesAsync();
        CloseModal();
    }
}
